# Admin girişi — .env.local olarak kopyalayın (git'e eklemeyin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=guclu-bir-sifre-buraya

# En az 32 karakter rastgele bir anahtar (ör: openssl rand -base64 32)
SESSION_SECRET=buraya-32-karakterden-uzun-gizli-anahtar-yazin

# İleride veritabanı için (Supabase örneği):
# DATABASE_URL=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
